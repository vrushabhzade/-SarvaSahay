# SarvaSahay Platform Environment Configuration
# Copy this file to .env and update values for your environment

# Application Settings
APP_NAME=SarvaSahay Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Security Settings (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long
ENCRYPTION_KEY=your-encryption-key-must-be-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
BCRYPT_ROUNDS=12

# Database Configuration
DATABASE_URL=postgresql://sarvasahay:sarvasahay123@localhost:5432/sarvasahay
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# AI/ML Configuration
ML_MODEL_PATH=ml/models/eligibility
ML_ACCURACY_THRESHOLD=0.89
ML_MAX_EVALUATION_TIME=5.0
ML_RETRAIN_INTERVAL=168

# Government API Configuration
PM_KISAN_API_URL=https://api.pmkisan.gov.in
DBT_API_URL=https://api.dbt.gov.in
PFMS_API_URL=https://api.pfms.gov.in
GOV_API_TIMEOUT=30
GOV_API_MAX_RETRIES=3
GOV_API_RETRY_DELAY=1.0

# Government API Keys (obtain from respective departments)
PM_KISAN_API_KEY=your-pm-kisan-api-key
DBT_API_KEY=your-dbt-api-key
PFMS_API_KEY=your-pfms-api-key

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=your-aws-account-id

# AWS S3 Configuration
AWS_S3_BUCKET_DOCUMENTS=sarvasahay-documents
AWS_S3_BUCKET_ML_MODELS=sarvasahay-ml-models
AWS_S3_BUCKET_BACKUPS=sarvasahay-backups
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# AWS Lambda Configuration
AWS_LAMBDA_ELIGIBILITY_FUNCTION=sarvasahay-eligibility-engine
AWS_LAMBDA_DOCUMENT_PROCESSOR=sarvasahay-document-processor
AWS_LAMBDA_OCR_FUNCTION=sarvasahay-ocr-processor
AWS_LAMBDA_NOTIFICATION_FUNCTION=sarvasahay-notification-handler
AWS_LAMBDA_TRACKING_FUNCTION=sarvasahay-tracking-updater
AWS_LAMBDA_TIMEOUT=300
AWS_LAMBDA_MEMORY=3008

# AWS API Gateway
AWS_API_GATEWAY_ENDPOINT=https://your-api-id.execute-api.ap-south-1.amazonaws.com
AWS_API_GATEWAY_STAGE=prod

# AWS Textract (OCR Service)
AWS_TEXTRACT_ENABLED=true
AWS_TEXTRACT_MAX_PAGES=10

# AWS Rekognition (Document Validation)
AWS_REKOGNITION_ENABLED=true
AWS_REKOGNITION_MIN_CONFIDENCE=80

# AWS SNS (Notifications)
AWS_SNS_TOPIC_ELIGIBILITY=arn:aws:sns:ap-south-1:ACCOUNT_ID:sarvasahay-eligibility
AWS_SNS_TOPIC_APPLICATIONS=arn:aws:sns:ap-south-1:ACCOUNT_ID:sarvasahay-applications
AWS_SNS_TOPIC_ALERTS=arn:aws:sns:ap-south-1:ACCOUNT_ID:sarvasahay-alerts

# AWS SQS (Message Queue)
AWS_SQS_QUEUE_DOCUMENTS=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/sarvasahay-documents
AWS_SQS_QUEUE_ELIGIBILITY=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/sarvasahay-eligibility
AWS_SQS_QUEUE_NOTIFICATIONS=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/sarvasahay-notifications

# AWS DynamoDB (NoSQL Database)
AWS_DYNAMODB_TABLE_SESSIONS=sarvasahay-sessions
AWS_DYNAMODB_TABLE_CACHE=sarvasahay-cache
AWS_DYNAMODB_TABLE_AUDIT=sarvasahay-audit-logs

# SMS Configuration (Twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Performance Settings
MAX_CONCURRENT_USERS=1000
MAX_SIMULTANEOUS_EVALUATIONS=10000
UPTIME_REQUIREMENT=0.995
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/sarvasahay/app.log
LOG_MAX_FILE_SIZE=100MB
LOG_BACKUP_COUNT=5

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "https://sarvasahay.gov.in"]
CORS_METHODS=["GET", "POST", "PUT", "DELETE"]

# Monitoring and Analytics
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Feature Flags
FEATURE_SMS_INTERFACE=true
FEATURE_VOICE_INTERFACE=true
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_AUTO_APPLICATION=true
FEATURE_REAL_TIME_TRACKING=trueAWS_S3_ENDPOINT_URL=http://localhost:4566
AWS_LAMBDA_ENDPOINT_URL=http://localhost:4566
AWS_DYNAMODB_ENDPOINT_URL=http://localhost:4566
AWS_SQS_ENDPOINT_URL=http://localhost:4566
AWS_SNS_ENDPOINT_URL=http://localhost:4566
